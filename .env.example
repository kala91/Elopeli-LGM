# ============================================================================
# LARP GAME ENGINE - CONFIGURATION
# ============================================================================
# Kopioi tämä tiedosto nimellä .env ja konfiguroi haluamasi mallit

# ============================================================================
# API PROVIDER SELECTION
# ============================================================================
# Valitse: 'ollama' (lokaali) tai 'openrouter' (pilvipalvelu)
API_PROVIDER=ollama

# ============================================================================
# OLLAMA CONFIGURATION (Lokaali kielimalli)
# ============================================================================
OLLAMA_MODEL=ministral-3:latest
# Muita vaihtoehtoja: gemma2, llama3.2, mistral, qwen2

# ============================================================================
# OPENROUTER CONFIGURATION (Pilvipalvelu)
# ============================================================================
# Hanki API key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxx
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# Ilmaisia malleja OpenRouterissa:
# - google/gemini-2.0-flash-exp:free (nopea, hyvä laatuinen)
# - meta-llama/llama-3.2-3b-instruct:free (pieni, nopea)
# - mistralai/mistral-7b-instruct:free (tasapainoinen)
# - qwen/qwen-2-7b-instruct:free (hyvä logiikassa)

# ============================================================================
# WORLD BUILDER (Automaattinen pelitilan analysointi)
# ============================================================================
# WorldBuilder käyttää erillistä kevyttä mallia maailman elementtien tunnistamiseen
# Suositellaan nopeaa mallia kuten Gemini Flash
WORLD_BUILDER_MODEL=google/gemini-2.0-flash-exp:free

# ============================================================================
# ENGINE RUNNER (Älykkäät aktivointipäätökset)
# ============================================================================
# EngineRunner vertaa story.json:ia world.json:iin ja päättää milloin aktivoida builderit
# Käyttää Ollaman functiongemma-mallia function calling -ominaisuuden kautta
ENABLE_ENGINE_RUNNER=true
ENGINE_RUNNER_MODEL=functiongemma:latest
