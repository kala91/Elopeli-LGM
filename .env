# OpenRouter API Configuration
# Kopioi tämä tiedosto nimellä .env ja lisää oma API key

# Päämalli: openrouter tai ollama
API_PROVIDER=openrouter

# Ollama-konfiguraatio (paikallinen)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma2:latest

# EngineRunner (vertaa story.json vs world.json, päättää buildereiden aktivoinnit)
# Käyttää Ollaman functiongemma-mallia function calling -ominaisuuden kautta
ENABLE_ENGINE_RUNNER=true
ENGINE_RUNNER_MODEL=functiongemma:latest

# OpenRouter-konfiguraatio (pilvi)
OPENROUTER_API_KEY=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
OPENROUTER_MODEL=google/gemma-3-27b-it:free

# WorldBuilder käyttää samaa mallia kuin päämalli (gemma-3 toimii hyvin)
WORLD_BUILDER_MODEL=google/gemma-3-27b-it:free